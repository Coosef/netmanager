# === DATABASE ===
POSTGRES_USER=netmgr
POSTGRES_PASSWORD=netmgr123
POSTGRES_DB=network_manager

# === SECURITY ===
# Generate: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=changeme-generate-with-fernet

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === APP ===
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALLOWED_ORIGINS=http://localhost:3000

# === CELERY ===
SSH_MAX_CONCURRENT=50
SSH_CONNECT_TIMEOUT=30
SSH_COMMAND_TIMEOUT=60

# === FLOWER (Celery Monitor) ===
FLOWER_USER=admin
FLOWER_PASSWORD=admin123
